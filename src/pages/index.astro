---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/ContentCard.astro';
import {
  formatDate,
  getAllPublishedNotes,
  getPublishedCollection,
  getVisibleIssues,
  noteUrl,
  resolveIssueNotes,
} from '../lib/content';

const issues = await getVisibleIssues();
const allNotes = await getAllPublishedNotes();

const currentIssue = issues.find((item) => item.data.current) ?? issues[0];

const currentIssueNotes = currentIssue ? await resolveIssueNotes(currentIssue.data.includedNotes) : [];

// Latest Notes: exclude current issue, interviews, and showInRecentNotes:false, show up to 6
const currentIssueSlugs = new Set(currentIssueNotes.map((n) => n.data.slug));
const latestNotes = allNotes
  .filter((n) => !currentIssueSlugs.has(n.data.slug))
  .filter((n) => n.data.type !== 'interview')
  .filter((n) => n.data.showInRecentNotes !== false)
  .slice(0, 6);

// People: interviews split by kind
const allInterviews = await getPublishedCollection('interviews');
const relayInterviews = allInterviews.filter((e) => !e.data.interviewKind || e.data.interviewKind === 'relay');
const deepInterviews = allInterviews.filter((e) => e.data.interviewKind === 'deep');

const homeNavItems = [
  { href: '/issues', label: 'ISSUES', hangul: '이슈', desc: '묶어 읽기' },
  { href: '/notes', label: 'NOTES', hangul: '노트', desc: '현장 기록' },
  { href: '/people', label: 'PEOPLE', hangul: '피플', desc: '사람 따라가기' },
  { href: '/about', label: 'ABOUT', hangul: '소개', desc: '무엇을 기록하나' },
  { href: '/interview-proposal', label: 'CONTRIBUTE', hangul: '제안', desc: '다음 장면 보내기' },
] as const;
---

<BaseLayout hideSiteHeader>
  <!-- Hero -->
  <div class="world-block" aria-label="편집 세계관">
    <div class="world-display">
      <h1 class="world-title" aria-label="프론티어노트, the future is nowhere / the future is now here">
        <span class="world-title-ko">프론티어노트</span>
        <span class="world-giant mono" id="worldPhrase">thefuture<span class="w-is">is</span><span class="w-now">now</span><span class="w-here">here</span></span>
      </h1>
    </div>
    <div class="world-readings">
      <span class="world-reading-item" id="readingNowhere">→ the future is nowhere</span>
      <span class="world-reading-item" id="readingNowHere">→ the future is now here</span>
    </div>
    <p class="world-tagline">
      <span class="tagline-l1">미래는 아직 어디에도 없다. 그런데 AI 네이티브 창업가와 빌더의 손에는 이미 와 있다.</span>
      <span class="tagline-l2">프론티어노트는 그 장면을 이슈, 노트, 사람으로 묶어 기록하는 매거진이다.</span>
    </p>
    <nav class="home-path-nav" aria-label="프론티어노트 읽기 경로">
      <ul>
        {homeNavItems.map((item) => (
          <li>
            <a href={item.href}>
              <span class="path-label mono">{item.label}</span>
              <span class="path-hangul">{item.hangul}</span>
              <span class="path-desc">{item.desc}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <!-- Current Issue -->
  {currentIssue && (
    <section class="issue-feature" aria-label="현재 이슈">
      <div class="issue-feature-main">
        <div class="issue-number">
          <span>ISSUE {currentIssue.data.number ?? (currentIssue.data.slug ?? currentIssue.id).replace(/^issue-/i, '')}</span>
          {currentIssue.data.current && <span class="current-badge">Current</span>}
          <span class="mono" style="color: var(--faint); font-size: 0.6rem;">{formatDate(currentIssue.data.publishedAt)}</span>
        </div>
        <h2>
          {currentIssue.data.publicPath
            ? <a href={currentIssue.data.publicPath} class="issue-title-link">{currentIssue.data.title}</a>
            : currentIssue.data.title
          }
        </h2>
        {currentIssue.data.coverImage && (
          <div class="issue-cover-img">
            <img src={currentIssue.data.coverImage} alt={currentIssue.data.title} />
          </div>
        )}
        <p class="issue-feature-desc">{currentIssue.data.description}</p>
        <div class="tag-list issue-feature-tags">
          {currentIssue.data.themes.map((theme) => (
            <span class="tag">{theme}</span>
          ))}
        </div>
      </div>

      <div class="issue-feature-toc">
        <p class="issue-toc-label mono">콘텐츠 구성</p>
        {currentIssueNotes.length ? (
          <ul class="issue-toc-list">
            {currentIssueNotes.map((note, i) => (
              <li>
                <a href={noteUrl(note)} class="toc-note-link">
                  <span class="toc-meta">
                    <span class="toc-num mono">{String(i + 1).padStart(2, '0')}</span>
                    <span class="toc-type">[{note.data.type.toUpperCase().replace('-', ' ')}]</span>
                  </span>
                  <span class="toc-title">{note.data.title}</span>
                  {note.data.subtitle && <span class="toc-subtitle">{note.data.subtitle}</span>}
                </a>
              </li>
            ))}
          </ul>
        ) : currentIssue.data.upcomingNotes?.length ? (
          <ul class="issue-toc-list">
            {currentIssue.data.upcomingNotes.map((upcoming, i) => (
              <li class="toc-upcoming">
                <span class="toc-note-link">
                  <span class="toc-meta">
                    <span class="toc-num mono">{String(i + 1).padStart(2, '0')}</span>
                    <span class="toc-type">[{upcoming.type}]</span>
                  </span>
                  <span class="toc-title toc-title-upcoming">{upcoming.title}</span>
                </span>
              </li>
            ))}
          </ul>
        ) : (
          <p class="mono" style="font-size: var(--text-xs); color: var(--faint);">수록 글 준비중</p>
        )}
        <div style="margin-top: 1rem; padding-top: 0.75rem; border-top: 1px solid var(--line);">
          <a href="/issues" class="mono" style="font-size: var(--text-xs); color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em;">전체 이슈 보기 →</a>
        </div>
      </div>
    </section>
  )}

  <!-- Latest Notes -->
  {latestNotes.length > 0 && (
    <section aria-label="최근 노트">
      <div class="section-title">
        <h2>최근 노트</h2>
        <a class="mono section-link muted" href="/notes">전체 보기 →</a>
      </div>
      <p class="section-desc muted">이슈 안팎에서 새로 기록한 글</p>
      <div class="latest-notes-list">
        {latestNotes.map((entry) => (
          <ContentCard entry={entry} variant="compact" showCollection />
        ))}
      </div>
    </section>
  )}

  <!-- People -->
  <section aria-label="사람들">
    <div class="section-title">
      <h2>사람들</h2>
      <a class="mono section-link muted" href="/people">전체 보기 →</a>
    </div>

    {relayInterviews.length > 0 && (
      <div class="people-sub">
        <p class="people-kind-label mono">한줄 릴레이 인터뷰</p>
        <p class="people-kind-desc muted">한줄 릴레이 인터뷰는 최전선에서 일하는 사람들의 한 문장을 따라가는 인터뷰다.</p>
        <div class="people-list">
          {relayInterviews.slice(0, 3).map((entry) => (
            <ContentCard entry={entry} variant="compact" />
          ))}
        </div>
      </div>
    )}

    {deepInterviews.length > 0 && (
      <div class="people-sub" style="margin-top: 1.5rem;">
        <p class="people-kind-label mono">심층 인터뷰</p>
        <p class="people-kind-desc muted">한 사람의 작업 방식과 기획 의도가 특정 Issue와 어떻게 연결되는지 길게 따라가는 글이다.</p>
        <div class="people-list">
          {deepInterviews.map((entry) => (
            <ContentCard entry={entry} variant="compact" />
          ))}
        </div>
      </div>
    )}
  </section>

  <!-- Archive Links -->
  <section class="archive-links-section" aria-label="아카이브">
    <div class="archive-links">
      <a href="/issues" class="archive-link mono">지난 이슈 보기 →</a>
      <a href="/notes" class="archive-link mono">전체 노트 보기 →</a>
      <a href="/people" class="archive-link mono">사람들 보기 →</a>
    </div>
  </section>

</BaseLayout>

<script>
  const phrase = document.getElementById('worldPhrase');
  const rNowhere = document.getElementById('readingNowhere');
  const rNowHere = document.getElementById('readingNowHere');

  if (phrase && rNowhere && rNowHere) {
    const phraseEl = phrase;
    const rNowhereEl = rNowhere;
    const rNowHereEl = rNowHere;
    let stateA = true;

    function applyState() {
      if (stateA) {
        phraseEl.classList.add('state-a');
        phraseEl.classList.remove('state-b');
        rNowhereEl.classList.add('reading-active');
        rNowhereEl.classList.remove('reading-dim');
        rNowHereEl.classList.remove('reading-active');
        rNowHereEl.classList.add('reading-dim');
      } else {
        phraseEl.classList.add('state-b');
        phraseEl.classList.remove('state-a');
        rNowhereEl.classList.remove('reading-active');
        rNowhereEl.classList.add('reading-dim');
        rNowHereEl.classList.add('reading-active');
        rNowHereEl.classList.remove('reading-dim');
      }
    }

    applyState();
    setInterval(() => {
      stateA = !stateA;
      applyState();
    }, 2600);
  }
</script>

<style>
  /* ── 세계관 블록: 초대형 타이포 ─────────── */
  .world-block {
    padding: var(--home-opening-space) 0 1rem;
    border-top: 0;
    border-bottom: 1px solid var(--line);
  }

  .world-display {
    line-height: 1;
    margin-bottom: 0.62rem;
  }

  .world-title {
    display: grid;
    gap: 0.24rem;
    margin: 0;
  }

  .world-title-ko {
    font-family: var(--font-title);
    font-size: clamp(2.1rem, 4.6vw, 4.9rem);
    font-weight: 400;
    letter-spacing: -0.012em;
    line-height: 1.02;
    color: var(--text);
    word-break: keep-all;
  }

  .world-giant {
    margin: 0;
    display: block;
    font-family: var(--font-mono);
    font-size: clamp(1.35rem, 4.6vw, 5.3rem);
    font-weight: 400;
    letter-spacing: -0.055em;
    line-height: 0.95;
    color: var(--text);
    white-space: nowrap;
  }

  /* 세계관 애니메이션 스팬 */
  .w-is,
  .w-now {
    display: inline;
    padding: 0 0.05em;
    transition: background-color 0.55s ease, color 0.55s ease;
  }

  /* w-here: padding-left로 공백 등장/소멸 */
  .w-here {
    display: inline;
    padding: 0 0.05em;
    transition:
      background-color 0.55s ease,
      color 0.55s ease,
      padding-left 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* state-a: "nowhere" — 붙어있음 */
  #worldPhrase.state-a .w-is { background: none; color: var(--text); }
  #worldPhrase.state-a .w-now { background: var(--accent); color: var(--accent-text); }
  #worldPhrase.state-a .w-here { background: var(--accent); color: var(--accent-text); padding-left: 0.05em; }

  /* state-b: "now here" — 공백 생김 */
  #worldPhrase.state-b .w-is { background: var(--accent); color: var(--accent-text); }
  #worldPhrase.state-b .w-now { background: var(--accent); color: var(--accent-text); }
  #worldPhrase.state-b .w-here { background: var(--accent); color: var(--accent-text); padding-left: 0.52em; }

  /* 리딩 텍스트 트랜지션 */
  .world-reading-item {
    transition: opacity 0.55s ease, color 0.55s ease;
  }

  .world-reading-item.reading-active {
    opacity: 1;
    color: var(--text);
  }

  .world-reading-item.reading-dim {
    opacity: 0.28;
    color: var(--faint);
  }

  .world-block .world-readings {
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    color: var(--faint);
    letter-spacing: 0.06em;
    flex-wrap: wrap;
  }

  .world-tagline {
    margin: 0.82rem 0 0;
    font-size: clamp(0.98rem, 1.45vw, 1.13rem);
    line-height: 1.58;
    color: var(--muted);
    max-width: 62ch;
    display: flex;
    flex-direction: column;
    gap: 0.12rem;
    word-break: keep-all;
    overflow-wrap: break-word;
  }

  .tagline-l1,
  .tagline-l2 {
    display: block;
  }

  .tagline-l2 {
    font-size: 0.9em;
    color: var(--text);
  }

  .home-path-nav {
    margin-top: 0.95rem;
    padding-top: 0.58rem;
    border-top: 1px solid var(--line);
  }

  .home-path-nav ul {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 1px solid var(--line);
  }

  .home-path-nav a {
    min-height: 4.2rem;
    display: grid;
    align-content: start;
    gap: 0.18rem;
    padding: 0.62rem 0.72rem 0.65rem;
    border-right: 1px solid var(--line);
    color: var(--muted);
    text-decoration: none;
  }

  .home-path-nav a:hover {
    background: var(--surface);
    color: var(--text);
  }

  .path-label {
    font-size: var(--text-2xs);
    letter-spacing: 0.09em;
    color: var(--faint);
  }

  .path-hangul {
    font-family: var(--font-title);
    font-size: var(--text-lg);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text);
  }

  .path-desc {
    font-size: var(--text-2xs);
    line-height: 1.35;
    color: var(--muted);
    word-break: keep-all;
  }

  /* ── 이슈 제목 링크 ──────────────────────── */
  .issue-title-link {
    color: inherit;
    text-decoration: none;
  }

  .issue-title-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.18rem;
  }

  /* ── upcoming TOC 항목 ──────────────────── */
  .toc-upcoming {
    opacity: 0.65;
  }

  .toc-title-upcoming {
    color: var(--muted);
    font-style: italic;
  }

  /* ── 인터뷰 시리즈 설명 ──────────────────── */
  .interviews-series-desc {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    margin: -0.4rem 0 0.55rem;
  }

  /* ── 인터뷰 그리드 ─────────────────────── */
  .interviews-grid {
    border-top: 1px solid var(--line-strong);
    align-items: flex-start;
  }

  .interviews-lead {
    padding-right: 1.2rem;
    display: grid;
    gap: 0;
    border-right: 1px solid var(--line);
  }

  .interviews-list {
    padding-left: 1.1rem;
    border-top: none;
  }

  /* compact 엔트리 위에 border-top이 있으므로 첫 번째는 없앰 */
  .interviews-list .editorial-entry:first-child {
    border-top: none;
    padding-top: 0;
  }

  /* ── 현장 노트 목록 ──────────────────── */
  .field-notes-list .editorial-entry:first-child {
    border-top: none;
    padding-top: 0;
  }

  /* ── 리서치 헤더 ─────────────────────── */
  .research-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-bottom: 0.6rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--line-strong);
  }

  .research-more {
    font-size: 0.62rem;
    color: var(--faint);
    letter-spacing: 0.08em;
    text-decoration: none;
  }

  .research-more:hover {
    color: var(--text);
  }

  /* ── section link ──────────────────── */
  .section-link {
    font-size: var(--text-xs);
    letter-spacing: 0.09em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .section-link:hover {
    color: var(--text);
  }

  /* ── New section styles ──────────────── */
  .section-desc {
    font-size: var(--text-sm);
    line-height: 1.6;
    margin: 0 0 0.8rem;
    max-width: 60ch;
  }

  .latest-notes-list .editorial-entry:first-child {
    border-top: 1px solid var(--line-strong);
  }

  .people-sub {
    padding-top: 0.8rem;
    border-top: 1px solid var(--line);
  }

  .people-kind-label {
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--faint);
    margin: 0 0 0.3rem;
  }

  .people-kind-desc {
    font-size: var(--text-sm);
    line-height: 1.6;
    margin: 0 0 0.75rem;
    max-width: 60ch;
  }

  .people-list .editorial-entry:first-child {
    border-top: 1px solid var(--line-strong);
  }

  .archive-links-section {
    padding: 1.5rem 0;
    border-top: 1px solid var(--line);
  }

  .archive-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
  }

  .archive-link {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    text-decoration: none;
  }

  .archive-link:hover {
    color: var(--text);
  }

  .toc-num {
    font-size: var(--text-2xs);
    color: var(--faint);
    min-width: 1.6rem;
    flex-shrink: 0;
  }

  /* ── 반응형 ──────────────────────────── */
  @media (max-width: 1024px) {
    .interviews-grid {
      grid-template-columns: 1fr;
    }

    .interviews-lead {
      padding-right: 0;
      border-right: none;
      border-bottom: 1px solid var(--line);
      padding-bottom: 0.85rem;
    }

    .interviews-list {
      padding-left: 0;
      padding-top: 0;
    }

    .interviews-list .editorial-entry:first-child {
      padding-top: 0.72rem;
      border-top: 1px solid var(--line);
    }
  }



  @media (max-width: 768px) {
    .world-block {
      padding-top: clamp(1.25rem, 7vw, 1.65rem);
    }

    .world-title {
      gap: 0.16rem;
    }

    .world-title-ko {
      font-size: clamp(2rem, 11vw, 2.85rem);
      letter-spacing: -0.012em;
    }

    .world-giant {
      font-size: clamp(1.42rem, 6.9vw, 2rem);
      letter-spacing: -0.085em;
    }

    .world-block .world-readings {
      flex-direction: column;
      gap: 0.2rem;
    }

    .world-tagline {
      font-size: clamp(0.95rem, 4.5vw, 1.12rem);
      line-height: 1.55;
      max-width: 100%;
    }

    .tagline-l2 {
      font-size: 0.82em;
    }

    .home-path-nav {
      margin-top: 0.68rem;
      padding-top: 0.5rem;
    }

    .home-path-nav ul {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      border-left: none;
    }

    .home-path-nav a {
      min-height: auto;
      display: inline-flex;
      align-items: baseline;
      gap: 0.28rem;
      padding: 0.34rem 0.48rem;
      border: 1px solid var(--line);
      background: var(--bg-soft);
    }

    .path-label,
    .path-desc {
      display: none;
    }

    .path-hangul {
      font-family: var(--font-sans);
      font-size: var(--text-sm);
      line-height: 1.1;
    }

    .interviews-series-desc {
      margin: -0.2rem 0 0.4rem;
    }

    .section-title {
      flex-wrap: wrap;
      gap: 0.3rem;
    }
  }
</style>
