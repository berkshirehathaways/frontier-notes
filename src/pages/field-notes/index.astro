---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { getPublishedCollection } from '../../lib/content';

const notes = await getPublishedCollection('field-notes');
---

<BaseLayout title="Field Notes" description="행사와 커뮤니티 현장에서 발견한 신호를 기록합니다.">
  <section class="frame heading">
    <p class="eyebrow mono">Field Signals</p>
    <h1>Field Notes</h1>
    <p class="muted">글 카드에는 location, tools, signals, date를 표시합니다.</p>
  </section>

  <section class="grid-3">
    {notes.map((entry) => (
      <ContentCard entry={entry} />
    ))}
  </section>
</BaseLayout>

<style>
  .heading {
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .heading h1 {
    margin: 0.2rem 0 0.4rem;
  }
</style>
