---
import type { NoteEntry } from '../lib/content';
import { formatDate, noteUrl } from '../lib/content';
import { SITE } from '../lib/site';

interface Props {
  entry: NoteEntry;
  related: NoteEntry[];
}

const { entry, related } = Astro.props;
---

<article class="note-detail">
  <header class="frame detail-head">
    <p class="eyebrow mono">{entry.data.type.toUpperCase()}</p>
    <h1>{entry.data.title}</h1>
    <p class="subtitle">{entry.data.subtitle}</p>
    <p class="muted mono">
      {formatDate(entry.data.date)} / issue: {entry.data.issue}
    </p>
  </header>

  <section class="detail-grid">
    <section class="frame content-wrap">
      <div class="prose">
        <slot />
      </div>
    </section>

    <aside class="side-stack">
      <section class="meta-panel frame">
        <h2 class="mono">Metadata</h2>
        <dl>
          <div>
            <dt>person</dt>
            <dd>{entry.data.person || 'n/a'}</dd>
          </div>
          <div>
            <dt>tools</dt>
            <dd>{entry.data.tools.length ? entry.data.tools.join(', ') : 'n/a'}</dd>
          </div>
          <div>
            <dt>themes</dt>
            <dd>{entry.data.themes.length ? entry.data.themes.join(', ') : 'n/a'}</dd>
          </div>
          <div>
            <dt>signals</dt>
            <dd>{entry.data.signals.length ? entry.data.signals.join(', ') : 'n/a'}</dd>
          </div>
          <div>
            <dt>location</dt>
            <dd>{entry.data.location || 'n/a'}</dd>
          </div>
        </dl>
      </section>

      <section class="frame questions">
        <h2 class="mono">다음 질문</h2>
        <ul>
          {(entry.data.next_questions.length
            ? entry.data.next_questions
            : ['이 방식이 다음 6개월 동안 어떻게 변하는가?']).map((question) => <li>{question}</li>)}
        </ul>
      </section>

      <section class="frame cta-area">
        <h2 class="mono">다음 액션</h2>
        <a class="cta-card" href={`mailto:${SITE.contactEmail}?subject=다음에%20만날%20사람%20추천`}>
          다음에 만날 사람 추천하기
        </a>
        <a class="cta-card" href={`mailto:${SITE.contactEmail}?subject=비슷한%20작업%20방식%20제보`}>
          비슷한 작업 방식을 가진 사람 제보하기
        </a>
        <a class="cta-card" href="#newsletter">월간 노트 구독하기</a>
      </section>
    </aside>
  </section>

  {related.length ? (
    <section class="frame related-wrap">
      <h2 class="mono">관련 글</h2>
      <ul>
        {related.map((item) => (
          <li>
            <a href={noteUrl(item)}>
              {item.data.title} <span class="muted">({item.collection})</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ) : null}
</article>

<style>
  .note-detail {
    display: grid;
    gap: 1rem;
  }

  .detail-head,
  .meta-panel,
  .content-wrap,
  .questions,
  .cta-area,
  .related-wrap {
    padding: 1.2rem 1.15rem 1.12rem;
  }

  .detail-head h1 {
    margin: 0.2rem 0 0.5rem;
    font-size: clamp(2rem, 4vw, 2.95rem);
    line-height: 1.14;
  }

  .subtitle {
    margin: 0;
    color: var(--muted);
  }

  .detail-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(0, 0.8fr);
    gap: 0.82rem;
    align-items: flex-start;
  }

  .side-stack {
    display: grid;
    gap: 0.8rem;
  }

  .meta-panel h2,
  .questions h2,
  .cta-area h2,
  .related-wrap h2 {
    margin-top: 0;
    margin-bottom: 0.72rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  dl {
    margin: 0;
    display: grid;
    gap: 0.4rem;
  }

  dl div {
    display: grid;
    grid-template-columns: 84px 1fr;
    gap: 0.55rem;
    border-top: 1px solid var(--line);
    padding-top: 0.44rem;
  }

  dt {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    color: #555;
    font-size: 0.73rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  dd {
    margin: 0;
    font-size: 0.89rem;
  }

  .cta-area {
    display: grid;
    gap: 0.48rem;
  }

  .cta-card {
    display: flex;
    align-items: center;
    min-height: 62px;
    border: 1px solid var(--line-strong);
    border-radius: 0;
    padding: 0.72rem;
    background: var(--surface-strong);
    font-weight: 600;
    line-height: 1.33;
    text-decoration: none;
  }

  .related-wrap ul,
  .questions ul {
    margin: 0;
    padding-left: 1.1rem;
  }

  .related-wrap li + li,
  .questions li + li {
    margin-top: 0.35rem;
  }

  @media (max-width: 980px) {
    .detail-grid {
      grid-template-columns: 1fr;
    }

    .content-wrap {
      order: 1;
    }

    .side-stack {
      order: 2;
    }
  }
</style>
