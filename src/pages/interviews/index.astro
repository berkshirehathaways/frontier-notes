---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { getPublishedCollection } from '../../lib/content';

const interviews = await getPublishedCollection('interviews');
---

<BaseLayout title="Interviews" description="사람 인터뷰를 통해 AI native builder의 태도와 신호를 기록합니다.">
  <section class="frame heading">
    <p class="eyebrow mono">People Interviews</p>
    <h1>Interviews</h1>
    <p class="muted">글 카드에는 person, role, tools, signals, date를 표시합니다.</p>
  </section>

  <section class="grid-3">
    {interviews.map((entry) => (
      <ContentCard entry={entry} />
    ))}
  </section>
</BaseLayout>

<style>
  .heading {
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .heading h1 {
    margin: 0.2rem 0 0.4rem;
  }
</style>
