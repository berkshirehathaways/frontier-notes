---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, getPublishedNewsletters } from '../../lib/content';

const newsletters = await getPublishedNewsletters();
const featured = newsletters.find((entry) => entry.data.featured) ?? newsletters[0];
---

<BaseLayout title="Newsletter" description="월간 구독 노트와 브리핑 아카이브를 확인할 수 있습니다.">
  <section class="frame heading">
    <p class="eyebrow mono">Newsletter Archive</p>
    <h1>뉴스레터 아카이브</h1>
    <p class="muted">구독 UI와 함께 발행된 브리핑 아카이브를 축적합니다.</p>
  </section>

  {featured ? (
    <section class="frame featured">
      <p class="eyebrow mono">Featured Dispatch</p>
      <h2>
        <a href={`/newsletter/${featured.id}`}>{featured.data.title}</a>
      </h2>
      <p class="note-subtitle">{featured.data.subtitle}</p>
      <p class="muted">{featured.data.summary}</p>
      <div class="tag-list">
        <span class="tag mono">{formatDate(featured.data.date)}</span>
        {featured.data.topics.map((topic) => (
          <span class="tag">{topic}</span>
        ))}
      </div>
    </section>
  ) : null}

  <section class="archive-list">
    {newsletters.map((entry) => (
      <article class="frame archive-item">
        <div>
          <p class="mono muted">{formatDate(entry.data.date)}</p>
          <h2>
            <a href={`/newsletter/${entry.id}`}>{entry.data.title}</a>
          </h2>
          <p class="note-subtitle">{entry.data.subtitle}</p>
        </div>
        <div>
          <p class="muted">{entry.data.summary}</p>
          <div class="tag-list">
            {entry.data.topics.map((topic) => (
              <span class="tag">{topic}</span>
            ))}
          </div>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .heading,
  .featured {
    padding: 1.25rem;
    margin-bottom: 1rem;
  }

  .heading h1,
  .featured h2 {
    margin: 0.2rem 0 0.45rem;
  }

  .archive-list {
    display: grid;
    gap: 0.8rem;
  }

  .archive-item {
    padding: 1.1rem 1.2rem;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: 1rem;
  }

  .archive-item h2 {
    margin: 0.2rem 0 0.3rem;
    font-size: 1.22rem;
  }

  @media (max-width: 900px) {
    .archive-item {
      grid-template-columns: 1fr;
    }
  }
</style>
