---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { formatDate, getPublishedNewsletters } from '../../lib/content';

export async function getStaticPaths() {
  const entries = await getPublishedNewsletters();
  return entries.map((entry) => ({ params: { slug: entry.id } }));
}

const slug = Astro.params.slug;
if (!slug) throw new Error('Missing newsletter slug');

const entry = await getEntry('newsletter', slug);
if (!entry) throw new Error('Newsletter not found');

const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.subtitle}>
  <article class="newsletter-detail">
    <header class="frame detail-head">
      <p class="eyebrow mono">Newsletter</p>
      <h1>{entry.data.title}</h1>
      <p class="note-subtitle">{entry.data.subtitle}</p>
      <p class="mono muted">{formatDate(entry.data.date)}</p>
      <div class="tag-list">
        {entry.data.topics.map((topic) => (
          <span class="tag">{topic}</span>
        ))}
      </div>
    </header>

    <section class="frame content-wrap">
      <div class="prose">
        <Content />
      </div>
    </section>

    <div id="newsletter">
      <NewsletterBlock />
    </div>
  </article>
</BaseLayout>

<style>
  .newsletter-detail {
    display: grid;
    gap: 1rem;
  }

  .detail-head,
  .content-wrap {
    padding: 1.2rem;
  }

  .detail-head h1 {
    margin: 0.2rem 0 0.45rem;
    font-size: clamp(1.7rem, 3vw, 2.3rem);
    line-height: 1.2;
  }

  .content-wrap {
    max-width: 860px;
  }
</style>
