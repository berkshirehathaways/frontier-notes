---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoteLayout from '../../layouts/NoteLayout.astro';
import { getAllPublishedNotes, getPublishedCollection } from '../../lib/content';
import FigureImage from '../../components/FigureImage.astro';

export async function getStaticPaths() {
  const entries = await getPublishedCollection('essays');
  return entries.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}

const { entry } = Astro.props;

const { Content } = await render(entry);
const allNotes = await getAllPublishedNotes();
const related = allNotes
  .filter((item) => item.id !== entry.id)
  .filter(
    (item) =>
      item.data.issue === entry.data.issue ||
      item.data.related_people.some((person) => entry.data.related_people.includes(person)) ||
      item.data.related_tools.some((tool) => entry.data.related_tools.includes(tool)),
  )
  .slice(0, 3);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.subtitle}
  image={entry.data.ogImage ?? entry.data.coverImage}
  ogType="article"
  publishedAt={entry.data.date}
>
  <NoteLayout entry={entry} related={related}>
    <Content components={{ FigureImage }} />
  </NoteLayout>
</BaseLayout>
