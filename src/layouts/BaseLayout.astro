---
import { HUB_NAV, MAIN_NAV, SITE } from '../lib/site';
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  ogType?: 'website' | 'article';
  publishedAt?: Date;
  hideSiteHeader?: boolean;
}

const { title, description = SITE.description, image, ogType = 'website', publishedAt, hideSiteHeader = false } = Astro.props;
const pageTitle = title ? `${title} | ${SITE.title}` : `${SITE.title} ${SITE.englishName}`;
const currentPath = Astro.url.pathname;
const canonicalUrl = Astro.url.href;
const origin = Astro.url.origin;
const resolvedImage = image?.trim() || SITE.defaultOgImage;
const ogImageUrl = new URL(resolvedImage, origin).toString();
const isDefaultOgImage = resolvedImage === SITE.defaultOgImage;
const isActiveNav = (href: string) => currentPath === href || currentPath.startsWith(`${href}/`);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="ko_KR" />
    {ogType === 'article' && publishedAt && (
      <meta property="article:published_time" content={publishedAt.toISOString()} />
    )}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    {isDefaultOgImage && (
      <>
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
      </>
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/variable/pretendardvariable-dynamic-subset.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="site-shell">

      {!hideSiteHeader && (
        <>
          <div class="topbar">
            <a href="/" class="topbar-id" aria-label="홈으로 이동: 프론티어노트 thefutureisnowhere">
              <span class="topbar-brand">{SITE.title}:</span>
              <span class="topbar-sentence mono" id="headerPhrase">thefuture<span class="th-is">is</span><span class="th-now">now</span><span class="th-here">here</span></span>
            </a>
            <nav class="util-nav" aria-label="유틸리티 메뉴">
              <ul>
                {HUB_NAV.map((item) => (
                  <li>
                    <a
                      class={currentPath.startsWith(item.href) ? 'active' : ''}
                      href={item.href}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>

          <nav class="primary-nav" aria-label="메인 메뉴">
            <ul>
              {MAIN_NAV.map((item) => (
                <li>
                  <a
                    class={isActiveNav(item.href) ? 'active' : ''}
                    href={item.href}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </>
      )}

      <main class:list={[hideSiteHeader && 'main-flush']}>
        <slot />
      </main>

      <!-- 푸터: 매거진 콜로폰 -->
      <footer class="footer">
        <div class="footer-inner">
          <div class="footer-brand">
            <p class="footer-brand-line">
              <span class="footer-name">{SITE.title}</span>
              <span class="mono footer-tagline">thefutureisnowhere</span>
            </p>
            <p class="footer-sub muted">AI 최전선의 아직 이름 붙지 않은 장면을 기록합니다.</p>
          </div>
          <nav class="footer-links" aria-label="푸터 메뉴">
            <a href="/issues">이슈</a>
            <a href="/notes">노트</a>
            <a href="/people">사람들</a>
            <a href="/about">소개</a>
            <a href="/interview-proposal">제안하기</a>
          </nav>
          <p class="footer-copy muted mono">
            {new Date().getFullYear()}. 모든 글은 현장에서 관찰한 기록입니다.
          </p>
        </div>
      </footer>

    </div>
    {import.meta.env.PROD && <Analytics />}
  </body>
</html>

<script>
  const hp = document.getElementById('headerPhrase');
  if (hp) {
    let stateA = true;
    const tick = () => {
      hp.classList.toggle('state-a', stateA);
      hp.classList.toggle('state-b', !stateA);
      stateA = !stateA;
    };
    tick();
    setInterval(tick, 2600);
  }
</script>

<style>
  /* ── 상단 바 ─────────────────────────────── */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.48rem 0;
    border-bottom: 1px solid var(--line);
    font-size: var(--text-2xs);
  }

  .topbar-id {
    display: inline-flex;
    flex-direction: row;
    align-items: baseline;
    gap: 0.42em;
    text-decoration: none;
    flex-shrink: 0;
  }

  .topbar-brand {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--text);
    white-space: nowrap;
  }

  .topbar-sentence {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    letter-spacing: 0.04em;
    color: var(--muted);
    font-weight: 400;
    white-space: nowrap;
  }

  .topbar-id:hover .topbar-sentence {
    color: var(--text);
  }

  .util-nav ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.15rem 0.7rem;
    justify-content: flex-end;
  }

  .util-nav a {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.09em;
    text-decoration: none;
  }

  .util-nav a:hover,
  .util-nav a.active {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 0.16rem;
  }

  /* ── 메인 내비게이션 ────────────────────────── */
  .primary-nav {
    padding: 0.5rem 0 0.55rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 0;
  }

  .primary-nav ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0 1.5rem;
  }

  .primary-nav a {
    display: inline-block;
    padding: 0.08rem 0;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--muted);
    text-decoration: none;
    border-bottom: 1.5px solid transparent;
  }

  .primary-nav a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .primary-nav a.active {
    color: var(--text);
    border-bottom-color: var(--text);
  }

  /* main 위 간격 */
  main {
    margin-top: 1.5rem;
  }

  main.main-flush {
    margin-top: 0;
  }

  /* ── 푸터 ────────────────────────────────── */
  .footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 2px solid var(--text);
  }

  .footer-inner {
    display: grid;
    gap: 0.75rem;
  }

  .footer-brand-line {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45em;
    margin: 0;
  }

  .footer-name {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--text);
  }

  .footer-tagline {
    font-size: var(--text-2xs);
    letter-spacing: 0.05em;
    color: var(--muted);
  }

  .footer-sub {
    font-size: var(--text-sm);
    margin: 0.2rem 0 0;
  }

  .footer-world {
    margin-top: 0.15rem;
  }

  .footer-world .world-main-sm {
    text-align: left;
    font-size: 0.62rem;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem 1.1rem;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--muted);
  }

  .footer-links a:hover {
    color: var(--text);
  }

  .footer-copy {
    font-size: var(--text-2xs);
    margin: 0;
  }

  /* ── 헤더 phrase 애니메이션 ──────────────── */
  .th-is,
  .th-now {
    display: inline;
    padding: 0 0.04em;
    transition: background-color 0.55s ease, color 0.55s ease;
  }

  .th-here {
    display: inline;
    padding: 0 0.04em;
    transition:
      background-color 0.55s ease,
      color 0.55s ease,
      padding-left 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* state-a: nowhere — now·here 하이라이트 */
  #headerPhrase.state-a .th-is  { background: none; color: var(--muted); }
  #headerPhrase.state-a .th-now { background: var(--accent); color: var(--accent-text); }
  #headerPhrase.state-a .th-here { background: var(--accent); color: var(--accent-text); padding-left: 0.04em; }

  /* state-b: now here — is·now·here 하이라이트, 공백 등장 */
  #headerPhrase.state-b .th-is  { background: var(--accent); color: var(--accent-text); }
  #headerPhrase.state-b .th-now { background: var(--accent); color: var(--accent-text); }
  #headerPhrase.state-b .th-here { background: var(--accent); color: var(--accent-text); padding-left: 0.38em; }

  /* ── 반응형 ──────────────────────────────── */
  @media (max-width: 768px) {
    /* 보조 nav 모바일 숨김 */
    .util-nav {
      display: none;
    }

    .primary-nav ul {
      gap: 0 1rem;
    }

    /* 네비게이션 아래 → 본문 시작까지 여백 축소 */
    main {
      margin-top: 0.85rem;
    }

    main.main-flush {
      margin-top: 0;
    }
  }
</style>
