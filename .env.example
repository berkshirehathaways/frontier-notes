# Keystatic production admin (GitHub mode) — server-side only, set in the
# deployment platform's environment settings. Never commit real values.
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=

# Public by design: PUBLIC_-prefixed variables are exposed to the client bundle.
# Only put values here that are safe to publish.
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# Local development only: include draft notes in dev builds.
SHOW_DRAFTS=false
