---
import { HUB_NAV, MAIN_NAV, SITE } from '../lib/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = SITE.description } = Astro.props;
const pageTitle = title ? `${title} | ${SITE.title}` : `${SITE.title} | ${SITE.englishName}`;
const currentPath = Astro.url.pathname;
const canonicalUrl = Astro.url.href;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content="/og-default.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-default.svg" />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body>
    <div class="site-shell">
      <div class="top-alert mono">
        <span>NEW</span>
        <a href="/newsletter">월간 노트 아카이브 보기</a>
      </div>
      <header class="header">
        <section class="masthead">
          <a href="/" class="brand">
            <span class="mono brand-kicker">Issue-based editorial archive for AI native builders</span>
            <strong>{SITE.title}</strong>
            <small>{SITE.englishName}</small>
          </a>
          <p class="muted intro">{SITE.subtitle}</p>
          <nav class="utility-nav" aria-label="유틸리티 메뉴">
            <ul>
              {
                HUB_NAV.map((item) => (
                  <li>
                    <a class={currentPath.startsWith(item.href) ? 'active' : ''} href={item.href}>
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
        </section>
        <nav class="primary-nav" aria-label="메인 메뉴">
          <ul>
            {
              MAIN_NAV.map((item) => (
                <li>
                  <a class={currentPath.startsWith(item.href) ? 'active' : ''} href={item.href}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="footer">
        <p class="mono">FRONTIER NOTES / FIELD SIGNAL ARCHIVE</p>
        <p class="muted">{SITE.subtitle}</p>
        <p class="footer-links">
          <a href="/newsletter">Newsletter Archive</a>
          <a href="/people">People</a>
          <a href="/tools">Tools</a>
          <a href="/interview-proposal">Interview Proposal</a>
        </p>
      </footer>
    </div>
  </body>
</html>

<style>
  .header {
    margin-bottom: 1.65rem;
    display: grid;
    gap: 0.58rem;
  }

  .top-alert {
    display: flex;
    align-items: center;
    gap: 0.52rem;
    border-bottom: 1px solid var(--line);
    padding: 0.22rem 0;
    font-size: 0.66rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .top-alert span {
    font-weight: 700;
  }

  .masthead {
    padding: 1.08rem 0;
    display: grid;
    gap: 0.68rem;
    grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr);
    align-items: end;
    border-bottom: 1px solid var(--line-strong);
  }

  .masthead .brand,
  .masthead .intro {
    grid-column: 1;
  }

  .masthead .utility-nav {
    grid-column: 2;
    grid-row: 1 / span 2;
    align-self: start;
  }

  .intro {
    margin: 0;
    max-width: 62ch;
    font-size: 0.93rem;
  }

  .primary-nav {
    border-bottom: 1px solid var(--line);
    padding: 0 0 0.6rem;
  }

  .primary-nav ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.38rem 0.72rem;
  }

  .brand {
    display: flex;
    flex-direction: column;
    gap: 0.08rem;
  }

  .brand strong {
    font-size: clamp(2.05rem, 3.8vw, 2.85rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .brand small {
    font-size: 0.74rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.11em;
  }

  .brand-kicker {
    font-size: 0.63rem;
    color: #5a5a5a;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .utility-nav ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.2rem 0.6rem;
  }

  .primary-nav a {
    display: inline-flex;
    align-items: center;
    padding: 0.06rem 0.24rem 0.08rem;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid transparent;
    text-decoration: none;
  }

  .utility-nav a {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0.02rem 0;
    border-radius: 0;
    font-size: 0.64rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
  }

  .primary-nav a.active {
    color: var(--text);
    border-bottom-color: var(--text);
  }

  .utility-nav a.active {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 0.16rem;
  }

  .footer {
    margin-top: 2rem;
    padding-top: 1.35rem;
    border-top: 1px solid var(--line-strong);
    display: grid;
    gap: 0.3rem;
  }

  .footer p {
    margin: 0;
  }

  .footer-links {
    display: flex;
    gap: 0.78rem;
    flex-wrap: wrap;
    font-size: 0.76rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }

  @media (max-width: 980px) {
    .masthead {
      grid-template-columns: 1fr;
    }

    .masthead .utility-nav {
      grid-column: 1;
      grid-row: auto;
    }

    .utility-nav ul {
      justify-content: flex-start;
      gap: 0.18rem 0.52rem;
    }
  }

  @media (max-width: 820px) {
    .primary-nav {
      padding: 0.4rem 0;
    }
  }
</style>
