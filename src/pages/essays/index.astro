---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { getPublishedCollection } from '../../lib/content';

const essays = await getPublishedCollection('essays');
---

<BaseLayout title="Essays" description="깊은 에세이를 통해 AI native generation의 작업 문화를 기록합니다.">
  <section class="frame heading">
    <p class="eyebrow mono">Deep Essays</p>
    <h1>Essays</h1>
    <p class="muted">글 카드에는 title, subtitle, issue, themes, date를 표시합니다.</p>
  </section>

  <section class="grid-3">
    {essays.map((entry) => (
      <ContentCard entry={entry} />
    ))}
  </section>
</BaseLayout>

<style>
  .heading {
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .heading h1 {
    margin: 0.2rem 0 0.4rem;
  }
</style>
