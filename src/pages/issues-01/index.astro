---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, resolveIssueNotes } from '../../lib/content';

const allIssues = await getCollection('issues');
const issue = allIssues.find((i) => i.data.publicPath === '/issues-01');

if (!issue) {
  return Astro.redirect('/issues', 307);
}

const notes = await resolveIssueNotes(issue.data.includedNotes);
const ogImage = issue.data.ogImage ?? issue.data.coverImage;
---

<BaseLayout
  title={issue.data.title}
  description={issue.data.description}
  image={ogImage}
>

  <!-- 이슈 헤더 -->
  <div class="issue-head">
    <div class="issue-eyebrow mono">
      <span>Issue {issue.data.number}</span>
      {issue.data.current && <span class="current-badge">Current</span>}
      <span class="issue-date">{formatDate(issue.data.publishedAt)}</span>
    </div>
    <h1 class="issue-title">{issue.data.title}</h1>

    {issue.data.coverImage && (
      <div class="issue-cover">
        <img src={issue.data.coverImage} alt={issue.data.title} />
      </div>
    )}

    <p class="issue-desc">{issue.data.description}</p>

    {issue.data.themes.length > 0 && (
      <div class="tag-list">
        {issue.data.themes.map((theme) => (
          <span class="tag">{theme}</span>
        ))}
      </div>
    )}
  </div>

  <!-- 콘텐츠 구성 -->
  <div class="issue-toc">
    <p class="toc-header mono">콘텐츠 구성 {notes.length}편</p>
    <ul class="toc-list">
      {notes.map((note, idx) => {
        const displayType = note.data.type.toUpperCase().replace('-', ' ');
        return (
          <li class="toc-item">
            <span class="toc-meta mono">
              <span class="toc-num">{String(idx + 1).padStart(2, '0')}</span>
              <span class="toc-type">[{displayType}]</span>
            </span>
            <div class="toc-body">
              <a href={`/${note.collection}/${note.id}`} class="toc-title">
                {note.data.title}
              </a>
              {note.data.subtitle && (
                <p class="toc-sub">{note.data.subtitle}</p>
              )}
            </div>
          </li>
        );
      })}
    </ul>
  </div>

  <!-- 아카이브 링크 -->
  <div class="issue-footer">
    <a href="/issues" class="mono archive-link">전체 이슈 보기 →</a>
  </div>

</BaseLayout>

<style>
  /* ── 이슈 헤더 ───────────────────────────── */
  .issue-head {
    padding: 1.5rem 0 0;
    border-top: 2px solid var(--text);
    display: grid;
    gap: 0.75rem;
  }

  .issue-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
  }

  .issue-date {
    color: var(--faint);
    letter-spacing: 0.04em;
  }

  .current-badge {
    display: inline-block;
    font-size: 0.6rem;
    background: var(--accent);
    color: var(--accent-text);
    padding: 0.08rem 0.4rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .issue-title {
    margin: 0;
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
    word-break: keep-all;
    overflow-wrap: break-word;
  }

  .issue-cover {
    width: 100%;
    overflow: hidden;
  }

  .issue-cover img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 7;
    object-fit: cover;
    object-position: center 35%;
  }

  .issue-desc {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.7;
    max-width: 66ch;
    word-break: keep-all;
  }

  /* ── 콘텐츠 구성 ─────────────────────────── */
  .issue-toc {
    margin-top: 2rem;
    padding-top: 1.1rem;
    border-top: 2px solid var(--text);
  }

  .toc-header {
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--faint);
    margin: 0 0 0.5rem;
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toc-item {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 1rem;
    padding: 0.85rem 0;
    border-top: 1px solid var(--line);
    align-items: start;
  }

  .toc-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 0.1rem;
  }

  .toc-num {
    font-size: var(--text-2xs);
    color: var(--faint);
    letter-spacing: 0.06em;
  }

  .toc-type {
    font-size: var(--text-2xs);
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .toc-body {
    display: grid;
    gap: 0.25rem;
    min-width: 0;
  }

  .toc-title {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.35;
    letter-spacing: -0.02em;
    color: var(--text);
    text-decoration: none;
    overflow-wrap: break-word;
    word-break: keep-all;
  }

  .toc-title:hover {
    text-decoration: underline;
    text-underline-offset: 0.18rem;
  }

  .toc-sub {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.5;
    margin: 0;
    overflow-wrap: break-word;
    word-break: keep-all;
  }

  /* ── 푸터 ───────────────────────────────── */
  .issue-footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .archive-link {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    text-decoration: none;
  }

  .archive-link:hover {
    color: var(--text);
  }

  /* ── 반응형 ──────────────────────────────── */
  @media (max-width: 768px) {
    .issue-head {
      padding-top: 1rem;
    }

    .toc-item {
      grid-template-columns: 1fr;
      gap: 0.3rem;
    }

    .toc-meta {
      flex-direction: row;
      align-items: center;
      gap: 0.5rem;
    }
  }
</style>
