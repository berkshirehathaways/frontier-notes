---
interface Props {
  themes: string[];
  tools: string[];
}

const { themes, tools } = Astro.props;
---

<section class="frame filter-wrap" aria-label="노트 필터">
  <p class="eyebrow mono">Client-side Filter</p>
  <div class="controls">
    <label>
      타입
      <select id="note-type-filter">
        <option value="">전체</option>
        <option value="essay">essay</option>
        <option value="interview">interview</option>
        <option value="field-note">field-note</option>
        <option value="system">system</option>
        <option value="report">report</option>
      </select>
    </label>

    <label>
      theme
      <select id="note-theme-filter">
        <option value="">전체</option>
        {themes.map((theme) => <option value={theme}>{theme}</option>)}
      </select>
    </label>

    <label>
      tool
      <select id="note-tool-filter">
        <option value="">전체</option>
        {tools.map((tool) => <option value={tool}>{tool}</option>)}
      </select>
    </label>
  </div>
</section>

<script>
  const typeSelect = document.querySelector('#note-type-filter');
  const themeSelect = document.querySelector('#note-theme-filter');
  const toolSelect = document.querySelector('#note-tool-filter');

  if (
    typeSelect instanceof HTMLSelectElement &&
    themeSelect instanceof HTMLSelectElement &&
    toolSelect instanceof HTMLSelectElement
  ) {
    const cards = Array.from(document.querySelectorAll('[data-note-card]')).filter(
      (card): card is HTMLElement => card instanceof HTMLElement,
    );

    const runFilter = () => {
      const type = typeSelect.value;
      const theme = themeSelect.value;
      const tool = toolSelect.value;

      cards.forEach((card) => {
        const matchesType = !type || card.dataset.type === type;
        const themes = card.dataset.themes?.split(',').filter(Boolean) ?? [];
        const tools = card.dataset.tools?.split(',').filter(Boolean) ?? [];
        const matchesTheme = !theme || themes.includes(theme);
        const matchesTool = !tool || tools.includes(tool);
        const visible = matchesType && matchesTheme && matchesTool;
        card.style.display = visible ? '' : 'none';
      });
    };

    typeSelect.addEventListener('change', runFilter);
    themeSelect.addEventListener('change', runFilter);
    toolSelect.addEventListener('change', runFilter);
  }
</script>

<style>
  .filter-wrap {
    padding: 0.9rem;
    margin-bottom: 1rem;
  }

  .controls {
    display: grid;
    gap: 0.6rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  label {
    display: grid;
    gap: 0.28rem;
    font-size: 0.84rem;
  }

  select {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 0.3rem;
    padding: 0.54rem 0.65rem;
    font: inherit;
    background: #fff;
  }

  @media (max-width: 768px) {
    .controls {
      grid-template-columns: 1fr;
    }
  }
</style>
