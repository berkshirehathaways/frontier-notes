{
  "name": "frontier-notes",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run build:public",
    "build:public": "ENABLE_KEYSTATIC=false astro build",
    "build:admin": "ENABLE_KEYSTATIC=true astro build",
    "build:full": "npm run build:admin",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "check": "npm run check:public && npm run check:content && npm run check:admin-structure && npm run typecheck",
    "check:public": "node scripts/check-public-safety.mjs",
    "check:content": "node scripts/check-content-links.mjs",
    "check:admin-structure": "node scripts/check-admin-structure.mjs",
    "admin": "astro dev --host 127.0.0.1 --port 4321",
    "admin:open": "bash scripts/open-admin.sh",
    "admin:stop": "bash scripts/stop-admin.sh"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.1",
    "@astrojs/react": "^5.0.6",
    "@astrojs/vercel": "^10.0.8",
    "@keystatic/astro": "^5.1.0",
    "@keystatic/core": "^0.5.50",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.4.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "@vercel/routing-utils": {
      "path-to-regexp": "6.3.0"
    },
    "@vercel/functions": {
      "ws": "^8.21.0"
    },
    "yaml-language-server": {
      "yaml": "^2.9.0"
    }
  }
}
