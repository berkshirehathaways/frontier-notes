---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { getPublishedCollection } from '../../lib/content';

const systems = await getPublishedCollection('systems');
---

<BaseLayout title="Systems" description="도구 리뷰가 아닌 작업 방식과 시스템 변화를 기록합니다.">
  <section class="frame heading">
    <p class="eyebrow mono">Work Systems</p>
    <h1>Systems</h1>
    <p class="muted">
      Cursor, Claude Code, Codex, GitHub, Supabase, cmux 같은 도구가 작업 순서를 어떻게 바꾸는지 추적합니다.
    </p>
  </section>

  <section class="grid-3">
    {systems.map((entry) => (
      <ContentCard entry={entry} />
    ))}
  </section>

  <section class="frame tool-link">
    <p class="muted">도구 중심 보기</p>
    <a class="mono" href="/tools">Tools 페이지 열기 →</a>
  </section>
</BaseLayout>

<style>
  .heading,
  .tool-link {
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .heading h1 {
    margin: 0.2rem 0 0.4rem;
  }
</style>
