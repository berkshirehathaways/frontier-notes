---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { getPublishedCollection } from '../../lib/content';

const reports = await getPublishedCollection('reports');
---

<BaseLayout title="Reports" description="월간/분기/반기 관찰 리포트가 쌓이는 공간입니다.">
  <section class="frame heading">
    <p class="eyebrow mono">Research Reports</p>
    <h1>Reports</h1>
    <p class="muted">MVP에서는 샘플 리포트 카드 1개를 기본으로 제공합니다.</p>
  </section>

  <section class="grid-2">
    {reports.map((entry) => (
      <ContentCard entry={entry} />
    ))}
  </section>
</BaseLayout>

<style>
  .heading {
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .heading h1 {
    margin: 0.2rem 0 0.4rem;
  }
</style>
